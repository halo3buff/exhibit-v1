{
  "name": "exhibit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/scripts/dev.ts",
    "extract": "tsx src/scripts/01-extract.ts",
    "transform": "tsx src/scripts/02-transform.ts",
    "load": "tsx src/scripts/03-load.ts",
    "pipeline": "npm run extract && npm run transform && npm run load",
    "clean:raw": "rm -rf data/raw/* && mkdir -p data/raw/met data/raw/artic data/raw/va data/raw/smithsonian data/raw/rijks",
    "clean:processed": "rm -rf data/processed/* && mkdir -p data/processed"
  },
  "dependencies": {
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "@types/node": "^22.13.10"
  }
}