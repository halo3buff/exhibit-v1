  // ── Rijks type= values ────────────────────────────────────────────────────
  console.log('\n── RIJKS type= VALUES ──');
  const RIJKS_TYPES = ['affiche','schilderij','prent','tekening','foto','aquarel','aardewerk','glas','meubilair','textiel','zilverwerk','goud'];
  for (const type of RIJKS_TYPES) {
