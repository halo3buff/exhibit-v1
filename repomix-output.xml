<body>

<header>
  <div class="header-left">
    <h1>NSFW Review</h1>
    <span class="stats" id="stats">Load nsfw-flagged.json to begin</span>
  </div>
  <div class="header-right">
    <div class="filter-btns">
      <button class="filter-btn active" onclick="setFilter('all')">All</button>
      <button class="filter-btn" onclick="setFilter('unreviewed')">Unreviewed</button>
      <button class="filter-btn" onclick="setFilter('kept')">Keeping</button>
      <button class="filter-btn" onclick="setFilter('deleted')">Deleting</button>
    </div>
    <button class="export-btn" onclick="exportJSON()">Export JSON</button>
  </div>
</header>

<div class="instructions">
  <strong>Click</strong> any image to review · <strong>Green = Keep</strong> (false positive, remove from flagged list) · <strong>Red = Delete</strong> (confirm NSFW, will be purged) · Unreviewed items are deleted by default · <strong>Export JSON</strong> when done, replace nsfw-flagged.json, then run <code>node scripts/nsfw-purge.mjs</code>
</div>

<div id="drop-zone">
  <h2>Visual NSFW Review</h2>
  <p>Load your flagged items JSON to begin</p>
  <button class="upload-btn" onclick="document.getElementById('file-input').click()">
    Load nsfw-flagged.json
  </button>
  <input type="file" id="file-input" accept=".json" onchange="loadFile(event)">
  <p style="margin-top:8px; font-size:9px;">Or drag & drop the file anywhere on this page</p>
</div>

<div id="grid" style="display:none"></div>

<div id="modal">
  <div class="modal-inner">
    <div class="modal-img-wrap" onclick="closeModal()">
      <img id="modal-img" src="" alt="">
    </div>
    <div class="modal-sidebar">
      <div>
        <div class="modal-source" id="modal-source"></div>
        <div class="modal-title" id="modal-title"></div>
      </div>
      <div class="modal-field"><label>Author</label><span id="modal-author"></span></div>
      <div class="modal-field"><label>Year</label><span id="modal-year"></span></div>
      <div class="modal-field"><label>Category</label><span id="modal-category"></span></div>
      <div class="modal-field" id="kw-field" style="display:none">
        <label>Keyword Match</label><span id="modal-keyword"></span>
      </div>
      <div>
        <div class="modal-field" style="margin-bottom:8px"><label>Detections</label></div>
        <div class="modal-detections" id="modal-detections"></div>
      </div>
      <a id="modal-link" href="#" target="_blank" class="modal-link">View at source →</a>
      <div class="modal-actions">
        <button class="modal-btn btn-keep"   onclick="markCurrent('kept')">✓ Keep</button>
        <button class="modal-btn btn-delete" onclick="markCurrent('deleted')">✕ Delete</button>
        <button class="modal-btn btn-close"  onclick="closeModal()">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
let items      = [];
let states     = {}; // id -> 'kept' | 'deleted' | null
let currentId  = null;
let filter     = 'all';

// ── File loading ─────────────────────────────────────────────────────────────
function loadFile(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => parseJSON(e.target.result);
  reader.readAsText(file);
}

document.addEventListener('dragover', e => e.preventDefault());
document.addEventListener('drop', e => {
  e.preventDefault();
  const file = e.dataTransfer.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => parseJSON(ev.target.result);
  reader.readAsText(file);
});

function parseJSON(text) {
  try {
    const data = JSON.parse(text);
    items = data.flagged || [];
    // Default all to 'deleted' — they're flagged, user marks keeps
    states = {};
    items.forEach(item => { states[item.id] = 'deleted'; });
    document.getElementById('drop-zone').style.display = 'none';
    document.getElementById('grid').style.display = 'grid';
    renderGrid();
    updateStats();
  } catch (err) {
    alert('Could not parse JSON: ' + err.message);
  }
}

// ── Rendering ─────────────────────────────────────────────────────────────────
function renderGrid() {
  const grid = document.getElementById('grid');
  const filtered = items.filter(item => {
    const s = states[item.id];
    if (filter === 'all')        return true;
    if (filter === 'unreviewed') return !s || s === 'deleted'; // all start as deleted
    if (filter === 'kept')       return s === 'kept';
    if (filter === 'deleted')    return s === 'deleted';
    return true;
  });

  if (filtered.length === 0) {
    grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1">No items in this view</div>';
    return;
  }

  grid.innerHTML = filtered.map(item => {
    const state    = states[item.id] || 'deleted';
    const imgSrc   = item.imageUrl ? `/api/img?url=${encodeURIComponent(item.imageUrl)}&size=400` : '';
    const triggers = (item.triggeredBy || []).filter(t => !t.startsWith('keyword')).join(', ');

    return `
      <div class="card ${state}" data-id="${item.id}" onclick="openModal('${item.id}')">
        <img src="${imgSrc}" alt="${escHtml(item.title || '')}" loading="lazy"
             onerror="this.style.opacity='0.2'">
        <div class="card-info">
          <div class="card-title">${escHtml(item.title || 'Untitled')}</div>
          <div class="card-meta">${escHtml(item.author || '')}${item.year ? ', ' + item.year : ''}</div>
          ${triggers ? `<div class="card-trigger">${escHtml(triggers)}</div>` : ''}
        </div>
      </div>
    `;
  }).join('');
}

function updateStats() {
  const total   = items.length;
  const kept    = Object.values(states).filter(s => s === 'kept').length;
  const deleted = Object.values(states).filter(s => s === 'deleted').length;
  document.getElementById('stats').textContent =
    `${total} flagged · ${kept} keeping · ${deleted} deleting`;
}

function setFilter(f) {
  filter = f;
  document.querySelectorAll('.filter-btn').forEach((btn, i) => {
    btn.classList.toggle('active', ['all','unreviewed','kept','deleted'][i] === f);
  });
  renderGrid();
}

// ── Modal ─────────────────────────────────────────────────────────────────────
function openModal(id) {
  const item = items.find(i => i.id === id);
  if (!item) return;
  currentId = id;

  document.getElementById('modal-img').src =
    item.imageUrl ? `/api/img?url=${encodeURIComponent(item.imageUrl)}&size=1200` : '';
  document.getElementById('modal-source').textContent   = item.source || '';
  document.getElementById('modal-title').textContent    = item.title  || 'Untitled';
  document.getElementById('modal-author').textContent   = item.author || '—';
  document.getElementById('modal-year').textContent     = item.year   || '—';
  document.getElementById('modal-category').textContent = item.category || '—';
  document.getElementById('modal-link').href            = item.link   || '#';

  if (item.keywordMatch) {
    document.getElementById('kw-field').style.display  = '';
    document.getElementById('modal-keyword').textContent = item.keywordMatch;
  } else {
    document.getElementById('kw-field').style.display  = 'none';
  }

  const dets = document.getElementById('modal-detections');
  if (item.detections && item.detections.length > 0) {
    dets.innerHTML = item.detections.map(d => {
      const score = d.score;
      const cls   = score >= 0.7 ? 'score-high' : score >= 0.5 ? 'score-med' : 'score-low';
      return `
        <div class="detection-row">
          <span class="detection-label">${escHtml(d.label.replace(/_/g,' '))}</span>
          <span class="detection-score ${cls}">${(score * 100).toFixed(0)}%</span>
        </div>`;
    }).join('');
  } else {
    dets.innerHTML = '<div class="detection-row"><span class="detection-label" style="opacity:0.4">Keyword match only</span></div>';
  }

  document.getElementById('modal').classList.add('open');
}

function closeModal() {
  document.getElementById('modal').classList.remove('open');
  currentId = null;
}

function markCurrent(state) {
  if (!currentId) return;
  states[currentId] = state;
  // Update card in grid
  const card = document.querySelector(`[data-id="${currentId}"]`);
  if (card) { card.className = `card ${state}`; }
  updateStats();
  closeModal();
}

document.getElementById('modal').addEventListener('click', e => {
  if (e.target === document.getElementById('modal')) closeModal();
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeModal();
  if (!currentId) return;
  if (e.key === 'k' || e.key === 'K') markCurrent('kept');
  if (e.key === 'd' || e.key === 'D') markCurrent('deleted');
});

// ── Export ─────────────────────────────────────────────────────────────────────
function exportJSON() {
  if (items.length === 0) { alert('Load a JSON file first.'); return; }

  // Only export items marked for deletion
  const toDelete = items.filter(item => states[item.id] === 'deleted');
  const kept     = items.filter(item => states[item.id] === 'kept');

  const output = {
    exportedAt:   new Date().toISOString(),
    totalFlagged: items.length,
    kept:         kept.length,
    flaggedCount: toDelete.length,
    flagged:      toDelete,
  };

  const blob = new Blob([JSON.stringify(output, null, 2)], { type: 'application/json' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = 'nsfw-flagged.json';
  a.click();
  URL.revokeObjectURL(url);

  alert(`Exported ${toDelete.length} items to delete.\n${kept.length} items marked as keep (removed from list).\n\nReplace scripts/nsfw-flagged.json with the downloaded file, then run:\nnode scripts/nsfw-purge.mjs`);
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
