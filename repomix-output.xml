  }

  console.log(`\n✅ ARTIC SPONGE HARVEST COMPLETE`);
  console.log(`   Total: ${totalNew} new items, ${totalDupes} duplicates skipped`);
  console.log(`   📁 /data/raw/artic/\n`);
}

