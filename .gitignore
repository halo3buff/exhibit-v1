# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# DATABASE
# %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# SQLite database and WAL/SHM journal files contain user data.
*.db
*.db-shm
*.db-wal

# %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# ETL PIPELINE DATA
# %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# Raw API dumps — immutable, re-harvestable, do not commit.
/data/raw/**
!/data/raw/**/.gitkeep

# Processed/transformed data — generated artifacts.
/data/processed/**
!/data/processed/.gitkeep

# Pipeline log files
/data/*.json

# Raw sample snapshots
raw-samples.json

# Source manifests — generated by the pipeline
/public/manifests/*.json

# %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# SCRIPTS & MAINTENANCE LOGS
# %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
scripts/moma_raw.json
scripts/nsfw-flagged.json
scripts/nsfw-purge-log.json
public/nsfw-review.html

# %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# LOCAL TOOLING
# %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# Claude Code local IDE settings and AI context (personal, machine-specific)
.claude/
CLAUDE.md

# Personal design references (mood board, internal briefs)
references/

# Deprecated one-off scripts superseded by scripts/migrate.js
scripts/migrate.mjs
scripts/migrate-canvas.mjs
scripts/migrate-canvas-v2.mjs
scripts/migrate-sessions.mjs
scripts/migrate-to-app-db.mjs
scripts/migrate-v2.mjs

# Local-only operational/debug scripts
scripts/test-fetch.mjs
scripts/prewarm-loop.bat
scripts/probe-lfa.ts
scripts/nsfw-scan.mjs
scripts/nsfw-purge.mjs
scripts/nsfw_scan.py

# Image cache — moved outside public for performance
.img-cache/
public/img-cache/

# Aider AI coding assistant
.aider*

# Repomix (AI code summarization tool — personal/local use only)
repomix-output.xml
repomix.config.json
.repomixignore

# npm lock file — this project uses pnpm (pnpm-lock.yaml)
package-lock.json

# Temp directory
tmp/

# Working notes / audit drafts (personal scratch space)
/work/
