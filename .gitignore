# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scripts
scripts/moma_raw.json

# %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# ETL PIPELINE DATA (Phase 1)
# %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
# Raw API dumps are immutable artifacts. Do not commit them.
/data/raw/**
!/data/raw/**/.gitkeep

# Processed data is generated. Do not commit unless it's a specific snapshot.
/data/processed/**
!/data/processed/.gitkeep

# Legacy manifest location (if migrating away from public/manifests)
/public/manifests/*.json


# Image cache - moved outside public for performance
.img-cache/
public/img-cache/
.aider*
